manifest {
    name        = 'scrna-seq-pipeline'
    description = 'End-to-end scRNA-seq analysis with bit-exact reproducibility'
    mainScript  = 'main.nf'
    nextflowVersion = '>=23.04'
}

params {
    // I/O
    input              = null
    outdir             = 'results'
    output_format      = null      // null → match input type
    keep_intermediates = false

    // Reproducibility
    seed               = 42
    threads            = 1

    // Flow control
    subsample          = null
    skip_doublet       = false
    skip_harmony       = false

    // Doublet
    doublet_rate       = null

    // QC
    min_genes          = null
    max_genes          = null
    min_umis           = null
    max_mito_pct       = null
    max_ribo_pct       = null

    // Embedding / integration
    hvg_flavor         = 'seurat'
    n_top_genes        = null
    n_pcs              = null
    harmony_theta      = null

    // Annotation
    singler_ref        = null
    singler_labels     = null
}

env {
    OMP_NUM_THREADS        = "${params.threads}"
    MKL_NUM_THREADS        = "${params.threads}"
    OPENBLAS_NUM_THREADS   = "${params.threads}"
    NUMEXPR_NUM_THREADS    = "${params.threads}"
    VECLIB_MAXIMUM_THREADS = "${params.threads}"
    PYTHONHASHSEED         = "${params.seed}"
}

profiles {
    standard { includeConfig 'conf/base.config' }
    test     { includeConfig 'conf/test.config' }
}

// Per-run trace (provenance complement to manifest.json)
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}
