// Default per-process settings. The conda env (`echocell`) is expected
// to already be active in the launching shell; no `conda` directive here.

process {
    executor   = 'local'
    cache      = 'lenient'
    errorStrategy = 'terminate'

    // Prepend the activated conda env's bin to PATH so `Rscript` resolves to
    // the env's R (with anndata, Seurat, etc.) and not the system R that
    // /usr/local/bin/Rscript would otherwise win on macOS.
    // Also set thread caps for belt-and-braces — nextflow.config env{} block
    // already covers these but Nextflow strips some env vars in subprocesses.
    beforeScript = """
        if [ -n "\${CONDA_PREFIX:-}" ]; then
            export PATH="\${CONDA_PREFIX}/bin:\${PATH}"
            # Force the R 'anndata' package (via reticulate) onto the conda
            # env's Python — otherwise reticulate may pull a cached arm64
            # Python that's incompatible with our osx-64 R under Rosetta.
            export RETICULATE_PYTHON="\${CONDA_PREFIX}/bin/python"
        fi
        export OMP_NUM_THREADS=${params.threads}
        export MKL_NUM_THREADS=${params.threads}
        export OPENBLAS_NUM_THREADS=${params.threads}
        export NUMEXPR_NUM_THREADS=${params.threads}
        export VECLIB_MAXIMUM_THREADS=${params.threads}
        export PYTHONHASHSEED=${params.seed}
    """
}

// Always copy final.* and PNGs out to outdir; intermediates depend on the
// keep_intermediates flag.
def keep = params.keep_intermediates
