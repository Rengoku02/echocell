// Smoke-test profile: exercises every stage end-to-end on Seurat's
// built-in pbmc_small (~80 cells x 230 genes). Skips DoubletFinder and
// Harmony because the dataset is too small for paramSweep / single-batch.

includeConfig 'base.config'

params {
    input          = "${projectDir}/test/data/test.rds"
    outdir         = 'results_test'
    skip_doublet   = true
    skip_harmony   = true
    output_format  = 'rds'
    n_top_genes    = 100   // 230 genes total → cap HVG count
    n_pcs          = 10    // small dataset → fewer PCs

    // pbmc_small is heavily downsampled — lower the gates so any cells survive.
    min_genes      = 10
    max_genes      = 500
    min_umis       = 50
    max_mito_pct   = 100
}
